# ============================================================
# Oracle Cloud — Variables de Entorno para Producción
# ============================================================
# Copia este archivo como .env en el servidor Oracle y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# ============================================================

# ── Quid App ─────────────────────────────────────────────────
POSTGRES_DB=quid
POSTGRES_USER=quid
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_POSTGRES
POSTGRES_PORT=5432
DATABASE_URL=postgresql://quid:CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_POSTGRES@postgres:5432/quid?schema=public
POSTGRES_DATABASE_URL=postgresql://quid:CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_POSTGRES@localhost:5432/quid?schema=public

NEXTAUTH_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_32_CHARS
NEXTAUTH_URL=https://TU_DOMINIO_O_IP_DE_ORACLE.com
NEXTAUTH_TRUSTHOST=true

NEXT_PUBLIC_VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=TU_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:tu@correo.com

CRON_SECRET=CAMBIA_ESTO_POR_UN_TOKEN_LARGO_CRON
CRON_INTERVAL_SECONDS=900

AURA_API_KEY=CAMBIA_ESTO_POR_UN_TOKEN_LARGO_AURA
OLLAMA_URL=http://host.docker.internal:11434/api
AURA_MODEL=hermes3:8b
AUTH_COOKIE_SECURE=true

# ── Aura Standalone ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=TU_TELEGRAM_BOT_TOKEN
QUID_API_URL=http://quid-app:3000/api/aura/sync
DEFAULT_USER_EMAIL=tu@correo.com
GROQ_API_KEY=TU_GROQ_API_KEY
TAVILY_API_KEY=TU_TAVILY_API_KEY
