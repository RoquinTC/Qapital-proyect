NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Push Notifications VAPID keys
# Generar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-clave-publica-vapid
VAPID_PRIVATE_KEY=tu-clave-privada-vapid
VAPID_SUBJECT=mailto:tu@email.com

TELEGRAM_BOT_TOKEN=your-token
TELEGRAM_ALLOWED_USER_IDS=123456789
GROQ_API_KEY=your-key
OPENROUTER_API_KEY=your-key
GOOGLE_AI_KEY=your-key
TAVILY_API_KEY=your-key
FIREBASE_SERVICE_ACCOUNT_JSON=your-json
POSTGRES_DB=quid
POSTGRES_USER=quid
POSTGRES_PASSWORD=quid-local-dev
POSTGRES_PORT=5432

# Local PostgreSQL DATABASE_URL used only for migration tests.
# The current app still uses Quid-App/.env while SQLite remains active.
POSTGRES_DATABASE_URL=postgresql://quid:quid-local-dev@localhost:5432/quid?schema=public
